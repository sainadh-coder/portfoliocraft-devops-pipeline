{
  "id": null,
  "uid": "portfoliocraft-main",
  "title": "PortfolioCraft — System & App Metrics",
  "tags": ["portfoliocraft", "devops"],
  "timezone": "browser",
  "schemaVersion": 36,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "CPU Usage (%)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "graphite", "uid": "Graphite" },
      "targets": [
        {
          "target": "aliasByNode(portfolio.system.cpu_percent,1)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percent", "min": 0, "max": 100 },
        "overrides": []
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Memory Usage (%)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "graphite", "uid": "Graphite" },
      "targets": [
        {
          "target": "aliasByNode(portfolio.system.mem_percent,1)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percent", "min": 0, "max": 100 },
        "overrides": []
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "HTTP Up",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 8 },
      "datasource": { "type": "graphite", "uid": "Graphite" },
      "targets": [
        {
          "target": "aliasByNode(portfolio.app.http_up,1)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" } } },
            { "type": "value", "options": { "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "graphMode": "none"
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Response Time (ms)",
      "gridPos": { "h": 8, "w": 18, "x": 6, "y": 8 },
      "datasource": { "type": "graphite", "uid": "Graphite" },
      "targets": [
        {
          "target": "aliasByNode(portfolio.app.response_time_ms,1)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ms", "min": 0 },
        "overrides": []
      }
    },
    {
      "id": 5,
      "type": "gauge",
      "title": "Uptime",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "graphite", "uid": "Graphite" },
      "targets": [
        {
          "target": "asPercent(summarize(portfolio.app.http_up,'10m','sum'),summarize(portfolio.app.http_up,'10m','count'))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 90 },
              { "color": "green", "value": 99 }
            ]
          }
        },
        "overrides": []
      }
    }
  ]
}
